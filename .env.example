# Copy this file to `.env` and fill in only the providers you intend to use.
# Recommended: configure variables in your shell or call `python-dotenv`
# explicitly in your script before using the library. Some adapters may also
# read `.env` from the current working directory, but explicit loading is the
# portable behavior to rely on.

# ----------------------------------------------------------------------------
# Text providers (easy_ai_clients.text)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=""
COHERE_API_KEY=""
DEEPINFRA_API_KEY=""
DEEPSEEK_API_KEY=""
FAL_KEY=""
FIREWORKS_API_KEY=""
GOOGLE_API_KEY=""
GROQ_API_KEY=""
HUGGINGFACE_API_KEY=""
MISTRAL_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
TOGETHER_API_KEY=""
XAI_API_KEY=""

# ----------------------------------------------------------------------------
# Audio synthesis providers (easy_ai_clients.audio.generate)
# ----------------------------------------------------------------------------
ELEVENLABS_API_KEY=""
# OPENAI_API_KEY, MISTRAL_API_KEY, GOOGLE_API_KEY, XAI_API_KEY,
# TOGETHER_API_KEY, DEEPINFRA_API_KEY are reused from the section above.

# ----------------------------------------------------------------------------
# Audio transcription providers (easy_ai_clients.audio.transcribe)
# ----------------------------------------------------------------------------
DEEPGRAM_API_KEY=""
DEEPGRAM_PROJECT_ID=""
SPEECHMATICS_API_KEY=""
# ELEVENLABS_API_KEY, FAL_KEY, FIREWORKS_API_KEY, TOGETHER_API_KEY are reused.

# ----------------------------------------------------------------------------
# Image providers (easy_ai_clients.image.generate / edit / remix / analyze)
# ----------------------------------------------------------------------------
BFL_API_KEY=""
STABILITY_API_KEY=""
# ANTHROPIC_API_KEY, FAL_KEY, FIREWORKS_API_KEY, GOOGLE_API_KEY,
# GROQ_API_KEY, OPENAI_API_KEY, OPENROUTER_API_KEY, TOGETHER_API_KEY,
# XAI_API_KEY are reused from the sections above.

# ----------------------------------------------------------------------------
# Video providers (easy_ai_clients.video)
# ----------------------------------------------------------------------------
RUNWAYML_API_SECRET=""
HEDRA_API_KEY=""
# FAL_KEY and GOOGLE_API_KEY are reused from the sections above.
# HEDRA_API_KEY is reserved for future Hedra video adapters; no current
# dispatcher requires it.
